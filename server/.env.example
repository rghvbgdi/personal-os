# Copy this to .env and fill in real values. NEVER commit .env.
NODE_ENV=development
PORT=8000

MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/personal-os?retryWrites=true&w=majority

JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Comma-separated list of allowed frontend origins (no trailing slash)
# e.g. https://my-app.vercel.app,https://my-app-git-main.vercel.app
CLIENT_URL=http://localhost:5173

BCRYPT_ROUNDS=12
