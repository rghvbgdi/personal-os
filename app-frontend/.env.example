# Copy and rename as needed, or just export inline when running expo start.
# On local dev, replace with your Mac's LAN IP so your iPhone can reach the server.
# e.g.  EXPO_PUBLIC_API_URL=http://192.168.1.42:8000/api/v1 npx expo start
# On production, use your Render URL.
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
